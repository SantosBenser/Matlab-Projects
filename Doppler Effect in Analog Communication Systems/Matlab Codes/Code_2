clc;
clear;
close all;

fc = 1000;      % Carrier frequency
v = 3e6;        % Increased velocity for visualization
c = 3e8;
fs = 100*fc;
t = 0:1/fs:0.01;

fd = (v/c)*fc;

carrier = cos(2*pi*fc*t);
doppler_signal = cos(2*pi*(fc+fd)*t);

figure;
plot(t, carrier);
hold on;
plot(t, doppler_signal);
legend('Original','Doppler Shifted');
title('Doppler Effect Visualization');
